{
  "name": "@dbaida/pi-builder",
  "version": "0.1.12",
  "description": "Personal Pi customization package that bootstraps a private editable config repository.",
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "coding-agent"
  ],
  "license": "MIT",
  "type": "module",
  "packageManager": "yarn@4.16.0",
  "homepage": "https://github.com/dmytrobaida/pi-builder#readme",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/dmytrobaida/pi-builder.git"
  },
  "bugs": {
    "url": "https://github.com/dmytrobaida/pi-builder/issues"
  },
  "publishConfig": {
    "access": "public"
  },
  "files": [
    "extensions",
    "user",
    "AGENTS.md",
    "CUSTOMIZE.md",
    "README.md",
    "LICENSE"
  ],
  "pi": {
    "extensions": [
      "./extensions/index.ts",
      "./user/extensions"
    ],
    "skills": [
      "./user/skills"
    ],
    "prompts": [
      "./user/prompts"
    ],
    "themes": [
      "./user/themes"
    ]
  },
  "scripts": {
    "format": "prettier --write .",
    "format:check": "prettier --check .",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "prepack": "yarn lint && yarn typecheck && yarn format:check",
    "release": "node scripts/release.mjs"
  },
  "peerDependencies": {
    "@earendil-works/pi-coding-agent": "*"
  },
  "devDependencies": {
    "@earendil-works/pi-coding-agent": "^0.79.4",
    "@eslint/js": "^10.0.1",
    "@types/node": "^25.9.3",
    "@types/string-argv": "^0.3.0",
    "eslint": "^10.5.0",
    "prettier": "^3.8.4",
    "typescript": "^6.0.3",
    "typescript-eslint": "^8.61.0"
  },
  "dependencies": {
    "string-argv": "^0.3.2"
  }
}
